# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# JWT Secrets (generate strong random strings)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# NLP Service (optional — regex fallback used if unavailable)
NLP_SERVICE_URL=http://localhost:5001

# Redis (optional — in-memory cache used if not set)
# REDIS_URL=redis://localhost:6379

# Twilio SMS (optional — leave blank to skip SMS)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# SMTP Email (optional — leave blank to skip email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AWS S3 (optional)
AWS_BUCKET=
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=
